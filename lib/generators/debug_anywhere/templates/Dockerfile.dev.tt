FROM ruby:<%= ruby_version %>-slim

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential git libsqlite3-dev libyaml-dev pkg-config && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /rails

ENV RAILS_ENV=development
# BUNDLE_PATH left at default (/usr/local/bundle) so the bind mount (.:/rails)
# does not overwrite gems installed during docker build.

# Copy Gemfile first for better layer caching.
# .ruby-version is required when Gemfile uses: ruby file: ".ruby-version"
COPY Gemfile Gemfile.lock ./
<% if File.exist?(File.join(destination_root, ".ruby-version")) %>
COPY .ruby-version ./
<% end %>
RUN bundle install

COPY . .

RUN groupadd --system --gid 1000 rails \
    && useradd --uid 1000 --gid 1000 --create-home rails \
    && chown -R rails:rails /rails /usr/local/bundle
USER rails

EXPOSE 3000
CMD ["bundle", "exec", "rails", "server", "-b", "0.0.0.0"]
